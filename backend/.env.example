# =============================================================================
# Beleqet Backend — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://beleqet_user:your_password@localhost:5432/beleqet_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

CHAPA_SECRET_KEY=CHASECK_TEST-...
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...
CHAPA_WEBHOOK_SECRET=your_webhook_secret
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@beleqet.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Beleqet <noreply@beleqet.com>

BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_board_password

# =============================================================================
# Global Payment Gateway (Task Global-Payments-001 — Stripe)
# Get keys from: https://dashboard.stripe.com/apikeys
# =============================================================================

# Secret key — server-side only, NEVER expose to frontend
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# Webhook signing secret — from Stripe Dashboard > Webhooks > your endpoint
# Required for HMAC verification of incoming Stripe events
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# Publishable key — safe to expose to frontend (Stripe.js)
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY

# =============================================================================
# Global Digital Wallet (Task Global-Payments-002 — PayPal)
# Get credentials from: https://developer.paypal.com/dashboard/applications
# =============================================================================

# PayPal REST API app credentials
PAYPAL_CLIENT_ID=REPLACE_WITH_YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=REPLACE_WITH_YOUR_PAYPAL_CLIENT_SECRET

# 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# Webhook ID from PayPal Developer Dashboard > Webhooks
# Leave empty to skip webhook signature verification (NOT safe for production)
PAYPAL_WEBHOOK_ID=REPLACE_WITH_YOUR_PAYPAL_WEBHOOK_ID

# Redirect URLs — must be HTTPS in production
PAYPAL_RETURN_URL=http://localhost:3000/payment/success
PAYPAL_CANCEL_URL=http://localhost:3000/payment/cancel
